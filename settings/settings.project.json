{
  "_comment": "Sample .claude/settings.json: permissions (first layer) + hooks (second). Verify permissions rule syntax at docs.claude.com/en/docs/claude-code/settings — it evolves. deny > ask > allow.",
  "permissions": {
    "deny": [
      "Read(./.env)", "Read(./.env.*)", "Read(**/secrets/**)", "Read(**/*.pem)",
      "Edit(./.env)", "Edit(./.env.*)",
      "Bash(git push --force:*)", "Bash(git push -f:*)",
      "Bash(sudo:*)",
      "WebFetch"
    ],
    "allow": [
      "Bash(go test:*)", "Bash(go build:*)", "Bash(go vet:*)", "Bash(gofmt:*)",
      "Bash(golangci-lint:*)", "Bash(sqlc generate)",
      "Bash(git status)", "Bash(git diff:*)", "Bash(git log:*)", "Bash(git add:*)",
      "Bash(git commit:*)", "Bash(git checkout:*)", "Bash(git branch:*)",
      "Bash(npm test:*)", "Bash(npm run lint:*)", "Bash(npx prettier:*)",
      "Bash(ls:*)", "Bash(cat:*)", "Bash(grep:*)", "Bash(rg:*)", "Bash(find:*)", "Bash(jq:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      { "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/secrets-scan.sh" },
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/fmt.sh" }
        ] }
    ],
    "PreToolUse": [
      { "matcher": "Bash",
        "hooks": [ { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard.sh" } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/tests-green.sh" } ] }
    ]
  }
}
