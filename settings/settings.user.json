{
  "_comment": "Sample ~/.claude/settings.json for the onboarding scenario (personal level, applies everywhere).",
  "permissions": {
    "deny": [
      "Read(**/.env)", "Read(**/.env.*)", "Read(**/*.pem)", "Read(**/secrets/**)",
      "Bash(git push --force:*)", "Bash(git push -f:*)", "Bash(sudo:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      { "matcher": "Bash",
        "hooks": [ { "type": "command", "command": "$HOME/.claude/hooks/guard.sh" } ] }
    ],
    "PostToolUse": [
      { "matcher": "Write|Edit",
        "hooks": [ { "type": "command", "command": "$HOME/.claude/hooks/secrets-scan.sh" } ] }
    ]
  }
}
